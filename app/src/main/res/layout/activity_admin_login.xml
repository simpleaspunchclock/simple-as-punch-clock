<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Login"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal"
            android:text="Enter your admin PIN to continue."
            android:textColor="@color/white" />

        <EditText
            android:id="@+id/editAdminPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Admin PIN"
            android:inputType="numberPassword"
            android:maxLength="4" />

        <!-- Recovery Question (only visible on first setup) -->
        <EditText
            android:id="@+id/editRecoveryQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Recovery question (e.g. Favorite city?)"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:visibility="gone" />

        <!-- Recovery Answer -->
        <EditText
            android:id="@+id/editRecoveryAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="One-word answer"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:visibility="gone" />

        <!-- Confirm Recovery Answer -->
        <EditText
            android:id="@+id/editRecoveryAnswerConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Confirm answer"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnEnter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/button_gray"
            android:text="Enter"
            android:textColor="@color/white" />
        <Button
            android:id="@+id/btnImportBackup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/button_gray"
            android:text="Import Backup"
            android:textColor="@color/white"
            android:visibility="gone" />
        <Button
            android:id="@+id/btnForgotPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/button_gray"
            android:text="Forgot PIN?"
            android:textColor="@color/white"
            android:visibility="gone" />
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/button_gray"
            android:text="Back"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>