<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/black"
	android:fitsSystemWindows="true"
	android:fillViewport="true">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center"
		android:orientation="vertical"
		android:padding="24dp">

		<TextView
			android:id="@+id/txtClock"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="12dp"
			android:gravity="center"
			android:text="12:00 PM"
			android:textColor="@color/white"
			android:textSize="@dimen/clock_text_size"
			android:textStyle="bold" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Punch Clock"
			android:textColor="@color/white"
			android:textSize="28sp"
			android:textStyle="bold" />

		<Button
			android:id="@+id/btnIn"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:minHeight="80dp"
			android:background="@drawable/button_rounded"
			android:backgroundTint="@color/button_green"
			android:text="PUNCH IN"
			android:textColor="@color/white"
			android:textSize="24sp" />

		<Button
			android:id="@+id/btnOut"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:minHeight="80dp"
			android:background="@drawable/button_rounded"
			android:backgroundTint="@color/button_red"
			android:text="PUNCH OUT"
			android:textColor="@color/white"
			android:textSize="24sp" />

		<Button
			android:id="@+id/btnAdmin"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:minHeight="56dp"
			android:background="@drawable/button_rounded"
			android:backgroundTint="@color/button_gray"
			android:text="ADMIN"
			android:textColor="@color/white" />

		<LinearLayout
			android:id="@+id/currentlyInCard"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:background="@drawable/currently_in_card_bg"
			android:orientation="vertical"
			android:padding="16dp"
			android:visibility="gone">

			<TextView
				android:id="@+id/txtCurrentlyInTitle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="8dp"
				android:text="CURRENTLY IN"
				android:textColor="@color/white"
				android:textSize="16sp"
				android:textStyle="bold" />

			<ScrollView
				android:id="@+id/currentlyInScroll"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:fillViewport="false"
				android:scrollbars="vertical">

				<LinearLayout
					android:id="@+id/currentlyInList"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical" />
			</ScrollView>

		</LinearLayout>

	</LinearLayout>

</ScrollView>
